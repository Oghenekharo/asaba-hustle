APP_NAME="Asaba Hustle"
APP_ENV=production
APP_DEBUG=false
APP_URL=https://your-domain.example
CONTAINER_APP_URL=https://your-domain.example

DB_CONNECTION=mysql
DB_HOST=your-mysql-host
DB_PORT=3306
DB_DATABASE=your_database
DB_USERNAME=your_user
DB_PASSWORD=change-me

MAIL_MAILER=smtp
MAIL_SCHEME=tls
MAIL_HOST=your-smtp-host
MAIL_PORT=587
MAIL_USERNAME=your-smtp-user
MAIL_PASSWORD=change-me
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS="no-reply@your-domain.example"
MAIL_FROM_NAME="${APP_NAME}"

REDIS_CLIENT=phpredis
REDIS_HOST=your-redis-host
REDIS_PASSWORD=change-me
REDIS_PORT=6379
CONTAINER_REDIS_HOST=your-redis-host
CONTAINER_REDIS_PORT=6379

BROADCAST_CONNECTION=reverb
CONTAINER_BROADCAST_CONNECTION=reverb
QUEUE_CONNECTION=redis
SESSION_DRIVER=redis
CACHE_STORE=redis

FILESYSTEM_DISK=public

REVERB_APP_ID=replace-me
REVERB_APP_KEY=replace-me
REVERB_APP_SECRET=replace-me
REVERB_HOST=your-reverb-host
REVERB_PORT=443
REVERB_SCHEME=https
CONTAINER_REVERB_HOST=your-reverb-host
CONTAINER_REVERB_PORT=443
CONTAINER_REVERB_SCHEME=https
CONTAINER_REVERB_SERVER_HOST=0.0.0.0
CONTAINER_REVERB_SERVER_PORT=8080

VITE_REVERB_APP_KEY="${REVERB_APP_KEY}"
VITE_REVERB_HOST="${REVERB_HOST}"
VITE_REVERB_PORT="${REVERB_PORT}"
VITE_REVERB_SCHEME="${REVERB_SCHEME}"
