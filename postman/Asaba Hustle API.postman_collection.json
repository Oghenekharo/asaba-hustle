            "url": { "raw": "{{baseUrl}}/jobs/{{openTransferJobId}}/mark-paid", "host": ["{{baseUrl}}"], "path": ["jobs", "{{openTransferJobId}}", "mark-paid"] }
          }
        },
        {
          "name": "Confirm Payment",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Accept", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{workerToken}}" }
            ],
            "url": { "raw": "{{baseUrl}}/jobs/{{openTransferJobId}}/confirm-payment", "host": ["{{baseUrl}}"], "path": ["jobs", "{{openTransferJobId}}", "confirm-payment"] }
          }
        },
        {
          "name": "Rate Job Participant",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Accept", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{authToken}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"rating\": 4.5,\n  \"review\": \"Smooth closeout from Postman\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": { "raw": "{{baseUrl}}/jobs/{{ratedJobId}}/rate", "host": ["{{baseUrl}}"], "path": ["jobs", "{{ratedJobId}}", "rate"] }
          }
        },
        {
          "name": "Suggested Workers",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Accept", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{authToken}}" }
            ],
            "url": { "raw": "{{baseUrl}}/jobs/{{openTransferJobId}}/suggested-workers", "host": ["{{baseUrl}}"], "path": ["jobs", "{{openTransferJobId}}", "suggested-workers"] }
          }
        },
        {
          "name": "My Jobs",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Accept", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{authToken}}" }
            ],
            "url": { "raw": "{{baseUrl}}/jobs/my/jobs", "host": ["{{baseUrl}}"], "path": ["jobs", "my", "jobs"] }
          }
        },
        {
          "name": "Search Jobs",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Accept", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{authToken}}" }
            ],
            "url": { "raw": "{{baseUrl}}/jobs/search?skill_id={{skillId}}", "host": ["{{baseUrl}}"], "path": ["jobs", "search"], "query": [{ "key": "skill_id", "value": "{{skillId}}" }] }
          }
        },
        {
          "name": "Admin Cancel Job",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Accept", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{adminToken}}" }
            ],
            "url": { "raw": "{{baseUrl}}/jobs/{{openTransferJobId}}/cancel", "host": ["{{baseUrl}}"], "path": ["jobs", "{{openTransferJobId}}", "cancel"] }
          }
        },
        {
          "name": "Admin Rollback Job",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Accept", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{adminToken}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"target_status\": \"payment_pending\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": { "raw": "{{baseUrl}}/jobs/{{ratedJobId}}/rollback", "host": ["{{baseUrl}}"], "path": ["jobs", "{{ratedJobId}}", "rollback"] }
          }
        }
      ]
    },
