    {
      "name": "Payments",
      "item": [
        {
          "name": "Initialize Paystack",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Accept", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{authToken}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"job_id\": {{legacyGatewayJobId}},\n  \"idempotency_key\": \"{{idempotencyKey}}\"\n}",
