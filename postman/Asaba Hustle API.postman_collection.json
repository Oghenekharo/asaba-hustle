    {
      "name": "Jobs",
      "item": [
        {
          "name": "List Jobs",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Accept", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{authToken}}" }
            ],
            "url": { "raw": "{{baseUrl}}/jobs", "host": ["{{baseUrl}}"], "path": ["jobs"] }
          }
        },
        {
          "name": "Show Job",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Accept", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{authToken}}" }
            ],
            "url": { "raw": "{{baseUrl}}/jobs/{{openTransferJobId}}", "host": ["{{baseUrl}}"], "path": ["jobs", "{{openTransferJobId}}"] }
          }
        },
        {
          "name": "Create Job",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Accept", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{authToken}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"skill_id\": {{skillId}},\n  \"title\": \"Postman Demo Job {{timestamp}}\",\n  \"description\": \"Testing the current API workflow.\",\n  \"budget\": 25000,\n  \"location\": \"Asaba\",\n  \"latitude\": 6.2,\n  \"longitude\": 6.73,\n  \"payment_method\": \"transfer\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": { "raw": "{{baseUrl}}/jobs", "host": ["{{baseUrl}}"], "path": ["jobs"] }
          }
        },
        {
          "name": "Apply To Job",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Accept", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{workerToken}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"amount\": 23000,\n  \"message\": \"I can handle this quickly and professionally.\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": { "raw": "{{baseUrl}}/jobs/{{openTransferJobId}}/apply", "host": ["{{baseUrl}}"], "path": ["jobs", "{{openTransferJobId}}", "apply"] }
          }
        },
        {
          "name": "Create Or Counter Negotiation",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Accept", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{workerToken}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"amount\": 23000,\n  \"message\": \"Updated offer from Postman\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": { "raw": "{{baseUrl}}/jobs/{{openTransferJobId}}/negotiate", "host": ["{{baseUrl}}"], "path": ["jobs", "{{openTransferJobId}}", "negotiate"] }
          }
        },
        {
          "name": "Accept Negotiation",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Accept", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{authToken}}" }
            ],
            "url": { "raw": "{{baseUrl}}/jobs/{{openTransferJobId}}/negotiate/{{negotiationId}}/accept", "host": ["{{baseUrl}}"], "path": ["jobs", "{{openTransferJobId}}", "negotiate", "{{negotiationId}}", "accept"] }
          }
        },
        {
          "name": "Counter Negotiation",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Accept", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{authToken}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"amount\": 22000,\n  \"message\": \"Client counter from Postman\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": { "raw": "{{baseUrl}}/jobs/{{openTransferJobId}}/negotiate/{{negotiationId}}/counter", "host": ["{{baseUrl}}"], "path": ["jobs", "{{openTransferJobId}}", "negotiate", "{{negotiationId}}", "counter"] }
          }
        },
        {
          "name": "Reject Negotiation",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Accept", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{authToken}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"message\": \"Rejected from Postman\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": { "raw": "{{baseUrl}}/jobs/{{openTransferJobId}}/negotiate/{{negotiationId}}/reject", "host": ["{{baseUrl}}"], "path": ["jobs", "{{openTransferJobId}}", "negotiate", "{{negotiationId}}", "reject"] }
          }
        },
        {
          "name": "Hire Worker",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Accept", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{authToken}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"worker_id\": {{workerId}}\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": { "raw": "{{baseUrl}}/jobs/{{openTransferJobId}}/hire", "host": ["{{baseUrl}}"], "path": ["jobs", "{{openTransferJobId}}", "hire"] }
          }
        },
        {
          "name": "Worker Accept Assigned Job",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Accept", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{workerToken}}" }
            ],
            "url": { "raw": "{{baseUrl}}/jobs/{{openTransferJobId}}/accept", "host": ["{{baseUrl}}"], "path": ["jobs", "{{openTransferJobId}}", "accept"] }
          }
        },
        {
          "name": "Worker Reject Assigned Job",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Accept", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{workerToken}}" }
            ],
            "url": { "raw": "{{baseUrl}}/jobs/{{openTransferJobId}}/reject", "host": ["{{baseUrl}}"], "path": ["jobs", "{{openTransferJobId}}", "reject"] }
          }
        },
        {
          "name": "Start Job",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Accept", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{workerToken}}" }
            ],
            "url": { "raw": "{{baseUrl}}/jobs/{{inProgressJobId}}/start", "host": ["{{baseUrl}}"], "path": ["jobs", "{{inProgressJobId}}", "start"] }
          }
        },
        {
          "name": "Complete Job",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Accept", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{workerToken}}" }
            ],
            "url": { "raw": "{{baseUrl}}/jobs/{{inProgressJobId}}/complete", "host": ["{{baseUrl}}"], "path": ["jobs", "{{inProgressJobId}}", "complete"] }
          }
        },
