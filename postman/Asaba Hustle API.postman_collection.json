          "name": "Mark Job Paid",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Accept", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{authToken}}" }
            ],
            "body": {
              "mode": "formdata",
              "formdata": [
                { "key": "receipt", "type": "file", "src": "{{receiptPath}}" }
