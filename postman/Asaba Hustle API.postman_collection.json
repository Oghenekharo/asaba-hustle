{"info":{"_postman_id":"f612b9c5-3a91-4c52-9fc5-9fd35ed66a01","name":"Asaba Hustle API","description":"Current Asaba Hustle API workflow. Primary happy path is negotiation-first hiring with manual payment methods (cash and transfer). Legacy Paystack and Flutterwave endpoints remain as optional compatibility checks.","schema":"https://schema.getpostman.com/json/collection/v2.1.0/collection.json"},"item":[{"name":"Public Auth","item":[{"name":"Register Phone User","request":{"method":"POST","header":[{"key":"Content-Type","value":"application/json"}],"body":{"mode":"raw","raw":"{\n  \"name\": \"Postman Phone User\",\n  \"phone\": \"{{registerPhone}}\",\n  \"password\": \"{{registerPassword}}\",\n  \"role\": \"worker\",\n  \"verification_method\": \"phone\",\n  \"primary_skill_id\": {{skillId}}\n}"},"url":"{{baseUrl}}/auth/register"},"event":[{"listen":"test","script":{"type":"text/javascript","exec":["const json = pm.response.json();","if (json.meta && json.meta.debug_token) pm.environment.set('phoneVerificationToken', json.meta.debug_token);"]}}]},{"name":"Register Email User","request":{"method":"POST","header":[{"key":"Content-Type","value":"application/json"}],"body":{"mode":"raw","raw":"{\n  \"name\": \"Postman Email User\",\n  \"phone\": \"{{registerEmailPhone}}\",\n  \"email\": \"{{registerEmail}}\",\n  \"password\": \"{{registerPassword}}\",\n  \"role\": \"client\",\n  \"verification_method\": \"email\",\n  \"primary_skill_id\": {{skillId}}\n}"},"url":"{{baseUrl}}/auth/register"},"event":[{"listen":"test","script":{"type":"text/javascript","exec":["const json = pm.response.json();","if (json.meta && json.meta.debug_link) pm.environment.set('emailVerificationLink', json.meta.debug_link);"]}}]},{"name":"Verify Seed Phone User","request":{"method":"POST","header":[{"key":"Content-Type","value":"application/json"}],"body":{"mode":"raw","raw":"{\n  \"phone\": \"{{seedPhoneVerificationPhone}}\",\n  \"token\": \"{{seedPhoneVerificationToken}}\"\n}"},"url":"{{baseUrl}}/auth/verify-phone"}},{"name":"Open Email Verification Link","request":{"method":"GET","url":"{{emailVerificationLink}}"}},{"name":"Login Client","request":{"method":"POST","header":[{"key":"Content-Type","value":"application/json"}],"body":{"mode":"raw","raw":"{\n  \"phone\": \"{{clientPhone}}\",\n  \"password\": \"{{clientPassword}}\"\n}"},"url":"{{baseUrl}}/auth/login"},"event":[{"listen":"test","script":{"type":"text/javascript","exec":["const json = pm.response.json();","if (json.data && json.data.token) pm.environment.set('authToken', json.data.token);","if (json.data && json.data.user && json.data.user.id) pm.environment.set('clientId', json.data.user.id);"]}}]},{"name":"Login Worker","request":{"method":"POST","header":[{"key":"Content-Type","value":"application/json"}],"body":{"mode":"raw","raw":"{\n  \"phone\": \"{{workerPhone}}\",\n  \"password\": \"{{workerPassword}}\"\n}"},"url":"{{baseUrl}}/auth/login"},"event":[{"listen":"test","script":{"type":"text/javascript","exec":["const json = pm.response.json();","if (json.data && json.data.token) pm.environment.set('workerToken', json.data.token);","if (json.data && json.data.user && json.data.user.id) pm.environment.set('workerId', json.data.user.id);"]}}]},{"name":"Login Admin","request":{"method":"POST","header":[{"key":"Content-Type","value":"application/json"}],"body":{"mode":"raw","raw":"{\n  \"phone\": \"{{adminPhone}}\",\n  \"password\": \"{{adminPassword}}\"\n}"},"url":"{{baseUrl}}/auth/login"},"event":[{"listen":"test","script":{"type":"text/javascript","exec":["const json = pm.response.json();","if (json.data && json.data.token) pm.environment.set('adminToken', json.data.token);"]}}]}]},{"name":"Skills","item":[{"name":"List Skills","request":{"method":"GET","url":"{{baseUrl}}/skills"},"event":[{"listen":"test","script":{"type":"text/javascript","exec":["const json = pm.response.json();","if (Array.isArray(json.data) && json.data.length > 0) pm.environment.set('skillId', json.data[0].id);"]}}]}]},{"name":"Authenticated Auth","item":[{"name":"Me","request":{"auth":{"type":"bearer","bearer":[{"key":"token","value":"{{authToken}}","type":"string"}]},"method":"GET","url":"{{baseUrl}}/auth/me"}},{"name":"Update Worker Availability","request":{"auth":{"type":"bearer","bearer":[{"key":"token","value":"{{workerToken}}","type":"string"}]},"method":"POST","header":[{"key":"Content-Type","value":"application/json"}],"body":{"mode":"raw","raw":"{\n  \"availability_status\": \"available\"\n}"},"url":"{{baseUrl}}/auth/availability"}}]},{"name":"Jobs and Negotiations","item":[{"name":"List Jobs","request":{"auth":{"type":"bearer","bearer":[{"key":"token","value":"{{authToken}}","type":"string"}]},"method":"GET","url":"{{baseUrl}}/jobs"},"event":[{"listen":"test","script":{"type":"text/javascript","exec":["const json = pm.response.json();","if (!Array.isArray(json.data)) return;","const lookup = title => json.data.find(job => job.title === title);","const openCashJob = lookup(pm.environment.get('seedOpenCashJobTitle'));","const openTransferJob = lookup(pm.environment.get('seedOpenTransferJobTitle'));","const inProgressJob = lookup(pm.environment.get('seedInProgressJobTitle'));","const ratedJob = lookup(pm.environment.get('seedRatedJobTitle'));","if (openCashJob) pm.environment.set('openCashJobId', openCashJob.id);","if (openTransferJob) pm.environment.set('openTransferJobId', openTransferJob.id);","if (inProgressJob) pm.environment.set('inProgressJobId', inProgressJob.id);","if (ratedJob) pm.environment.set('ratedJobId', ratedJob.id);"]}}]},{"name":"Show Seed Open Cash Job","request":{"auth":{"type":"bearer","bearer":[{"key":"token","value":"{{authToken}}","type":"string"}]},"method":"GET","url":"{{baseUrl}}/jobs/{{openCashJobId}}"}},{"name":"Create Transfer Job","request":{"auth":{"type":"bearer","bearer":[{"key":"token","value":"{{authToken}}","type":"string"}]},"method":"POST","header":[{"key":"Content-Type","value":"application/json"}],"body":{"mode":"raw","raw":"{\n  \"skill_id\": {{skillId}},\n  \"title\": \"Postman Transfer Job {{timestamp}}\",\n  \"description\": \"Negotiation-first lifecycle test from Postman.\",\n  \"budget\": 20000,\n  \"location\": \"Asaba Mall, Asaba\",\n  \"latitude\": 6.2011,\n  \"longitude\": 6.7288,\n  \"payment_method\": \"transfer\"\n}"},"url":"{{baseUrl}}/jobs"},"event":[{"listen":"prerequest","script":{"type":"text/javascript","exec":["pm.environment.set('timestamp', Date.now());"]}},{"listen":"test","script":{"type":"text/javascript","exec":["const json = pm.response.json();","if (json.data && json.data.id) pm.environment.set('createdJobId', json.data.id);"]}}]},{"name":"Worker Create Initial Offer","request":{"auth":{"type":"bearer","bearer":[{"key":"token","value":"{{workerToken}}","type":"string"}]},"method":"POST","header":[{"key":"Content-Type","value":"application/json"}],"body":{"mode":"raw","raw":"{\n  \"amount\": 18500,\n  \"message\": \"I can handle this job today for NGN 18,500.\"\n}"},"url":"{{baseUrl}}/jobs/{{createdJobId}}/negotiate"},"event":[{"listen":"test","script":{"type":"text/javascript","exec":["const json = pm.response.json();","if (json.data && json.data.id) pm.environment.set('negotiationId', json.data.id);"]}}]},{"name":"Client Reject With Counter","request":{"auth":{"type":"bearer","bearer":[{"key":"token","value":"{{authToken}}","type":"string"}]},"method":"POST","header":[{"key":"Content-Type","value":"application/json"}],"body":{"mode":"raw","raw":"{\n  \"amount\": 17000,\n  \"message\": \"Budget is tighter than expected. I can do NGN 17,000 if you can still come today.\"\n}"},"url":"{{baseUrl}}/jobs/{{createdJobId}}/negotiate/{{negotiationId}}/reject"}},{"name":"Worker Counter On Same Negotiation","request":{"auth":{"type":"bearer","bearer":[{"key":"token","value":"{{workerToken}}","type":"string"}]},"method":"POST","header":[{"key":"Content-Type","value":"application/json"}],"body":{"mode":"raw","raw":"{\n  \"amount\": 17500,\n  \"message\": \"I can meet in the middle at NGN 17,500 and still bring supplies.\"\n}"},"url":"{{baseUrl}}/jobs/{{createdJobId}}/negotiate"},"event":[{"listen":"test","script":{"type":"text/javascript","exec":["const json = pm.response.json();","if (json.data && json.data.id) pm.environment.set('negotiationId', json.data.id);"]}}]},{"name":"Client Accept Negotiation","request":{"auth":{"type":"bearer","bearer":[{"key":"token","value":"{{authToken}}","type":"string"}]},"method":"POST","url":"{{baseUrl}}/jobs/{{createdJobId}}/negotiate/{{negotiationId}}/accept"}},{"name":"Worker Reject Assigned Job (Alternative Path)","request":{"auth":{"type":"bearer","bearer":[{"key":"token","value":"{{workerToken}}","type":"string"}]},"method":"POST","url":"{{baseUrl}}/jobs/{{createdJobId}}/reject"}},{"name":"Worker Accept Job","request":{"auth":{"type":"bearer","bearer":[{"key":"token","value":"{{workerToken}}","type":"string"}]},"method":"POST","url":"{{baseUrl}}/jobs/{{createdJobId}}/accept"}},{"name":"Worker Start Job","request":{"auth":{"type":"bearer","bearer":[{"key":"token","value":"{{workerToken}}","type":"string"}]},"method":"POST","url":"{{baseUrl}}/jobs/{{createdJobId}}/start"}},{"name":"Worker Complete Job","request":{"auth":{"type":"bearer","bearer":[{"key":"token","value":"{{workerToken}}","type":"string"}]},"method":"POST","url":"{{baseUrl}}/jobs/{{createdJobId}}/complete"}},{"name":"Client Mark Paid","request":{"auth":{"type":"bearer","bearer":[{"key":"token","value":"{{authToken}}","type":"string"}]},"method":"POST","url":"{{baseUrl}}/jobs/{{createdJobId}}/mark-paid"}},{"name":"Worker Confirm Payment","request":{"auth":{"type":"bearer","bearer":[{"key":"token","value":"{{workerToken}}","type":"string"}]},"method":"POST","url":"{{baseUrl}}/jobs/{{createdJobId}}/confirm-payment"}},{"name":"Client Rate Worker","request":{"auth":{"type":"bearer","bearer":[{"key":"token","value":"{{authToken}}","type":"string"}]},"method":"POST","header":[{"key":"Content-Type","value":"application/json"}],"body":{"mode":"raw","raw":"{\n  \"rating\": 5,\n  \"review\": \"Completed successfully from the current negotiation-first Postman flow.\"\n}"},"url":"{{baseUrl}}/jobs/{{createdJobId}}/rate"}},{"name":"Worker Apply To Seed Open Cash Job","request":{"auth":{"type":"bearer","bearer":[{"key":"token","value":"{{workerToken}}","type":"string"}]},"method":"POST","header":[{"key":"Content-Type","value":"application/json"}],"body":{"mode":"raw","raw":"{\n  \"amount\": 16500,\n  \"message\": \"I can handle the cleaning job this afternoon.\"\n}"},"url":"{{baseUrl}}/jobs/{{openCashJobId}}/apply"}},{"name":"My Jobs","request":{"auth":{"type":"bearer","bearer":[{"key":"token","value":"{{authToken}}","type":"string"}]},"method":"GET","url":"{{baseUrl}}/jobs/my/jobs"}},{"name":"Admin Cancel Job (Alternative Path)","request":{"auth":{"type":"bearer","bearer":[{"key":"token","value":"{{adminToken}}","type":"string"}]},"method":"PATCH","url":"{{baseUrl}}/jobs/{{createdJobId}}/cancel"}}]},{"name":"Messages","item":[{"name":"List Conversations","request":{"auth":{"type":"bearer","bearer":[{"key":"token","value":"{{authToken}}","type":"string"}]},"method":"GET","url":"{{baseUrl}}/messages/conversations"},"event":[{"listen":"test","script":{"type":"text/javascript","exec":["const json = pm.response.json();","if (!Array.isArray(json.data)) return;","const conversation = json.data.find(item => item.job && item.job.title === pm.environment.get('seedInProgressJobTitle'));","if (conversation) pm.environment.set('conversationId', conversation.id);"]}}]},{"name":"Get Conversation Messages","request":{"auth":{"type":"bearer","bearer":[{"key":"token","value":"{{authToken}}","type":"string"}]},"method":"GET","url":"{{baseUrl}}/messages/conversation/{{conversationId}}"}},{"name":"Send Message","request":{"auth":{"type":"bearer","bearer":[{"key":"token","value":"{{authToken}}","type":"string"}]},"method":"POST","header":[{"key":"Content-Type","value":"application/json"}],"body":{"mode":"raw","raw":"{\n  \"job_id\": {{inProgressJobId}},\n  \"message\": \"Checking in from the updated Postman collection.\"\n}"},"url":"{{baseUrl}}/messages/send"}}]},{"name":"Notifications","item":[{"name":"List Notifications","request":{"auth":{"type":"bearer","bearer":[{"key":"token","value":"{{authToken}}","type":"string"}]},"method":"GET","url":"{{baseUrl}}/notifications"},"event":[{"listen":"test","script":{"type":"text/javascript","exec":["const json = pm.response.json();","if (Array.isArray(json.data) && json.data.length > 0) pm.environment.set('notificationId', json.data[0].id);"]}}]},{"name":"Mark Notification Read","request":{"auth":{"type":"bearer","bearer":[{"key":"token","value":"{{authToken}}","type":"string"}]},"method":"POST","header":[{"key":"Content-Type","value":"application/json"}],"body":{"mode":"raw","raw":"{\n  \"notification_id\": {{notificationId}}\n}"},"url":"{{baseUrl}}/notifications/read"}}]},{"name":"Legacy Gateway Endpoints","description":"Optional compatibility checks only. These are not part of the current seeded manual-payment workflow. They require a job whose payment_method is still set to paystack or flutterwave.","item":[{"name":"Initialize Paystack Payment","request":{"auth":{"type":"bearer","bearer":[{"key":"token","value":"{{authToken}}","type":"string"}]},"method":"POST","header":[{"key":"Content-Type","value":"application/json"},{"key":"Idempotency-Key","value":"{{idempotencyKey}}"}],"body":{"mode":"raw","raw":"{\n  \"job_id\": {{legacyGatewayJobId}}\n}"},"url":"{{baseUrl}}/payments/initialize"},"event":[{"listen":"test","script":{"type":"text/javascript","exec":["const json = pm.response.json();","if (json.data && json.data.reference) pm.environment.set('paystackReference', json.data.reference);"]}}]},{"name":"Verify Paystack Payment","request":{"auth":{"type":"bearer","bearer":[{"key":"token","value":"{{authToken}}","type":"string"}]},"method":"POST","header":[{"key":"Content-Type","value":"application/json"}],"body":{"mode":"raw","raw":"{\n  \"reference\": \"{{paystackReference}}\"\n}"},"url":"{{baseUrl}}/payments/verify"}},{"name":"Initialize Flutterwave Payment","request":{"auth":{"type":"bearer","bearer":[{"key":"token","value":"{{authToken}}","type":"string"}]},"method":"POST","header":[{"key":"Content-Type","value":"application/json"},{"key":"Idempotency-Key","value":"{{flutterwaveIdempotencyKey}}"}],"body":{"mode":"raw","raw":"{\n  \"job_id\": {{legacyGatewayJobId}}\n}"},"url":"{{baseUrl}}/payments/flutterwave/initialize"},"event":[{"listen":"test","script":{"type":"text/javascript","exec":["const json = pm.response.json();","if (json.data && json.data.reference) pm.environment.set('flutterwaveReference', json.data.reference);"]}}]},{"name":"Verify Flutterwave Payment","request":{"auth":{"type":"bearer","bearer":[{"key":"token","value":"{{authToken}}","type":"string"}]},"method":"POST","header":[{"key":"Content-Type","value":"application/json"}],"body":{"mode":"raw","raw":"{\n  \"transaction_id\": {{flutterwaveTransactionId}},\n  \"tx_ref\": \"{{flutterwaveReference}}\"\n}"},"url":"{{baseUrl}}/payments/flutterwave/verify"}}]}]}


