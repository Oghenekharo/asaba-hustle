REVERB_APP_ID=
REVERB_APP_KEY=
REVERB_APP_SECRET=
REVERB_HOST=reverb
REVERB_PORT=8080
REVERB_SCHEME=http
REVERB_SERVER_HOST=0.0.0.0
REVERB_SERVER_PORT=8080
CONTAINER_REVERB_HOST=reverb
CONTAINER_REVERB_PORT=8080
CONTAINER_REVERB_SCHEME=http
CONTAINER_REVERB_SERVER_HOST=0.0.0.0
