APP_NAME="Asaba Hustle"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://127.0.0.1:8000
CONTAINER_APP_URL=http://127.0.0.1:8000

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=mysql
DB_PORT=3306
DB_DATABASE=asaba_hustle
DB_USERNAME=asaba
DB_PASSWORD=secret

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=reverb
CONTAINER_BROADCAST_CONNECTION=reverb
FILESYSTEM_DISK=public
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=localhost

REDIS_CLIENT=phpredis
REDIS_HOST=redis
REDIS_PASSWORD=null
REDIS_PORT=6379
CONTAINER_REDIS_HOST=redis
CONTAINER_REDIS_PORT=6379

PASSWORD_RESET_TOKEN_TTL_MINUTES=30
CONTACT_VERIFICATION_TOKEN_TTL_MINUTES=10

MYSQL_DATABASE=asaba_hustle
MYSQL_USER=asaba
MYSQL_PASSWORD=secret
MYSQL_ROOT_PASSWORD=root

MAIL_MAILER=smtp
MAIL_SCHEME=null
MAIL_HOST=mailhog
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="test@asabahustle.com"
MAIL_FROM_NAME="${APP_NAME}"

NIGERIABULKSMS_USERNAME=
NIGERIABULKSMS_PASSWORD=
NIGERIABULKSMS_SENDER=
